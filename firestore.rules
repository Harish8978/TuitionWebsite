rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isUserAdmin() {
      return isAuthenticated() && request.auth.token.email == "workwithharishp@gmail.com";
    }

    function isUserStaff() {
      return isAuthenticated() && request.auth.token.email in ["prathipa014@gmail.com", "aaswindark@gmail.com"];
    }

    function isAdmin() {
      return isUserAdmin() || (isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isStudent() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }

    function isStaff() {
      return isUserStaff() || (isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff');
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, min, max) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= min && 
             request.resource.data[field].size() <= max;
    }

    // ===============================================================
    // Collections
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isUserAdmin() || isAdmin() || isStaff();
      allow create: if isAuthenticated() && isOwner(userId) && 
                      hasOnlyAllowedFields(['uid', 'email', 'displayName', 'role', 'grade', 'phone', 'createdAt']) &&
                      (request.resource.data.role in ['student', 'staff'] || (request.resource.data.role == 'admin' && request.auth.token.email == "workwithharishp@gmail.com"));
      allow update: if isUserAdmin() || isAdmin() || (isOwner(userId) && 
                      (request.resource.data.role == resource.data.role || request.auth.token.email in ["aaswindark@gmail.com", "prathipa014@gmail.com"]) &&
                      hasOnlyAllowedFields(['uid', 'email', 'displayName', 'role', 'grade', 'phone', 'createdAt'])) ||
                      (isStaff() && resource.data.role == 'student' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['grade']));
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /enquiries/{enquiryId} {
      allow create: if hasOnlyAllowedFields(['name', 'phone', 'grade', 'message', 'timestamp']) &&
                      isValidString('name', 1, 100) &&
                      isValidString('phone', 1, 20) &&
                      isValidString('message', 1, 2000);
      allow read, delete: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                      hasOnlyAllowedFields(['name', 'marks', 'feedback', 'timestamp']) &&
                      isValidString('name', 1, 100) &&
                      isValidString('feedback', 1, 1000);
      allow update, delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isAdmin() || isStaff() || (isAuthenticated() && resource.data.studentId == request.auth.uid);
      allow write: if isAdmin() || isStaff();
    }

    match /marks/{markId} {
      allow read: if isAdmin() || isStaff() || (isAuthenticated() && resource.data.studentId == request.auth.uid);
      allow write: if isAdmin() || isStaff();
    }

    match /notes/{noteId} {
      allow read: if isAdmin() || isStudent() || isStaff();
      allow create: if isStudent() && 
                      hasOnlyAllowedFields(['title', 'subject', 'grade', 'url', 'uploadedBy', 'studentId', 'timestamp']) &&
                      request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isAdmin() || (isStudent() && resource.data.studentId == request.auth.uid);
    }

    match /staffs/{staffId} {
      allow read: if isAdmin() || (isAuthenticated() && (request.auth.uid == resource.data.uid || request.auth.token.email == resource.data.email));
      allow update: if isAdmin() || (isAuthenticated() && 
                      (!('uid' in resource.data) || resource.data.uid == request.auth.uid) && 
                      request.auth.token.email == resource.data.email &&
                      hasOnlyAllowedFields(['uid', 'email', 'name', 'phone', 'subjects', 'dailySalary', 'joinDate', 'createdAt']));
      allow write: if isAdmin();
    }

    match /staffAttendance/{attendanceId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid));
      allow write: if isAuthenticated() && (request.resource.data.uid == request.auth.uid || isAdmin());
    }

    match /aiReports/{reportId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.studentId == request.auth.uid);
      allow create: if isStudent() && request.resource.data.studentId == request.auth.uid;
    }

    match /feedbacks/{feedbackId} {
      allow read: if isAdmin() || isStaff();
      allow create: if isAuthenticated();
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /advertisements/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery/{mediaId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
